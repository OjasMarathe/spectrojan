# Copy this file to `.env` (which is gitignored) and fill in your own API keys.
# DO NOT commit real keys to this file — `.env.example` is checked into git.

# Groq (free tier — get a key at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_key_here

# Google Gemini (free tier — get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key_here

# OpenAI (optional — paid)
OPENAI_API_KEY=sk-your_openai_key_here

# Optional: override default models
SPECTROJAN_OPENAI_MODEL=gpt-4o
SPECTROJAN_GEMINI_MODEL=gemini-2.5-flash
SPECTROJAN_GROQ_MODEL=llama-3.3-70b-versatile
# The attacker LLM used by twin_synthesizer (provider:model)
SPECTROJAN_ATTACKER_MODEL=groq:llama-3.3-70b-versatile
